{
  "extends": null,
  "appId": "com.indiacloud.panel",
  "productName": "IndiaCloud",
  "directories": {
    "buildResources": "public",
    "output": "dist"
  },
  "files": [
    "build/**/*",
    "electron/**/*",
    "node_modules/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "IndiaCloud"
  },
  "publish": null
}
